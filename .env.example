# ============================================================
# Email Campaign Manager – Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ----------------------------------------------------------
# MongoDB Configuration
# ----------------------------------------------------------
# Local MongoDB instance (default)
MONGODB_URI=mongodb://localhost:27017/

# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/?retryWrites=true&w=majority

# Name of the MongoDB database to use
MONGODB_DATABASE=email_campaigns

# ----------------------------------------------------------
# SMTP Configuration (Gmail example)
# ----------------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address
SMTP_USERNAME=your_email@gmail.com

# Gmail App Password (16 characters, generated from
# https://myaccount.google.com/apppasswords)
# Do NOT use your regular Gmail password here.
SMTP_PASSWORD=your_16_char_app_password

# Enable STARTTLS (True = port 587, False = plain)
# Set to False only if you change SMTP_PORT to 465 and use SMTP_SSL
SMTP_USE_TLS=True

# ----------------------------------------------------------
# Email Sender Details
# ----------------------------------------------------------
FROM_EMAIL=your_email@gmail.com
FROM_NAME=Your Name

# ----------------------------------------------------------
# Recipient Configuration
# ----------------------------------------------------------
# Comma-separated list of default recipient email addresses.
# Used by the built-in main() function and test_setup.py.
RECEIVER_EMAILS=recipient1@example.com,recipient2@example.com

# Default contact list name created when running main()
DEFAULT_CONTACT_LIST_NAME=Default Recipients
